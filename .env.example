# blog-agent 配置
# 用法:cp .env.example .env,按需填写

# 博客仓库本地路径
BLOG_ROOT=/home/mi/ai-blog

# LLM 后端 - MiLLM 内部网关
MILLM_BASE_URL=http://model.mify.ai.srv
MILLM_API_KEY=
MILLM_MODEL=claude-sonnet-4-5

# Cloudflare Pages 部署
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=d83188253c7c02411dadd510d6e50de8
CF_PAGES_PROJECT=ai-blog

# 线上域名 (用于 health 命令)
SITE_URL=https://ai-blog-61z.pages.dev

# 飞书通知 (可选)
FEISHU_WEBHOOK=
FEISHU_WEBHOOK_SECRET=
